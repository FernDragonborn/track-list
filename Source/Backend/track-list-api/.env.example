# Backend env — loaded by ASP.NET Core via DotNetEnv when running outside Docker
# (e.g. `dotnet run` or test runner). For Docker, root Source/.env is mounted.
# Copy to .env and fill in your own values. .env is gitignored.
#
# ⚠ Values here MUST stay in sync with Source/.env when both are used.
# See Source/.env.example header for the full list of .env files in this
# repo (root / backend / frontend / seeder / perf) and the rotation rules.

# ── Database ───────────────────────────────────────────
# SQLite default (file-based). For local `dotnet run`, the relative path is
# created next to the project; for Docker, use /app/data/tracklist.db.
CONNECTION_STRING="Data Source=tracklist.db;Cache=Shared;Mode=ReadWriteCreate;Foreign Keys=True"
FILE_STORAGE_PATH="./uploads"

# ── JWT ────────────────────────────────────────────────
# Generate a fresh long random secret per environment.
# Linux/macOS: openssl rand -base64 64
# Windows PS:  [Convert]::ToBase64String((1..64 | % { [byte](Get-Random -Max 256) }))
JWT_PRIVATE_KEY="CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET"
JWT_AUDIENCE="track-list-web"
JWT_ISSUER="track-list-api"

# ── Self-host security defaults ───────────────────────
TRACKLIST_SETUP_TOKEN="CHANGE_ME_GENERATE_A_LONG_RANDOM_SETUP_TOKEN"
TRACKLIST_PUBLIC_REGISTRATION=false
TRACKLIST_MAX_USERS=1
TRACKLIST_SEED_MODERATOR=false
TRACKLIST_ALLOWED_ORIGINS=
TRACKLIST_SHOW_PII=false

# ── External APIs ──────────────────────────────────────
# External HTTP integrations are opt-in. Enabling them leaks the searched
# media titles/external ids to that provider; DeepL also receives review text.
TRACKLIST_ENABLE_TMDB=false
TRACKLIST_ENABLE_OMDB=false
TRACKLIST_ENABLE_DEEPL=false
TRACKLIST_ENABLE_LETTERBOXD=false
TRACKLIST_ENABLE_WIKIPEDIA=false

# TMDB — media import + search. Free at
# https://www.themoviedb.org/settings/api
TMDBApiKey=

# OMDb — IMDb / RT / Metacritic ratings. Free 1000/day at
# http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# DeepL — translation of external content. Free 500k chars/month at
# https://www.deepl.com/en/your-account/keys (Free-tier keys end with `:fx`)
DEEPL_API_KEY=

# ── Frontend URL (optional same-origin /api override) ──
PUBLIC_API_URL=http://localhost/api
