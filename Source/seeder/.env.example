# Seeder env config — copy to .env and adjust.
# .env is gitignored.

# ── API target ─────────────────────────────────────────
# Point at running stack (Caddy reverse-proxy port).
SEED_API_BASE=http://localhost/api

# ── Admin credentials ──────────────────────────────────
# Used to log in as the first admin. If the DB is empty, the seeder creates
# this account through POST /api/setup/admin before continuing.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@tracklist.local
SEED_ADMIN_PASSWORD=seedPassword1

# Required when the API runs in a production-like environment where setup
# requires TRACKLIST_SETUP_TOKEN. Development usually does not need it.
SEED_SETUP_TOKEN=

# ── TMDB ───────────────────────────────────────────────
# Free key at https://www.themoviedb.org/settings/api
# Phase 1 + Phase 2 are no-ops without this.
# Same variable name as the backend (Source/.env) — single line can be
# shared across both files. Legacy TMDB_API_KEY is still accepted.
TMDBApiKey=
