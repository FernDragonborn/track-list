# Root compose env — consumed by docker-compose*.yaml (api + web containers).
# Copy to .env and fill in your own values. .env is gitignored.
#
# ───────────────────────────────────────────────────────────────────
# DUPLICATION NOTE (known wart, not yet refactored)
# ───────────────────────────────────────────────────────────────────
# The same values are read from multiple .env files depending on HOW
# the component is started. Keep them in sync until we centralize.
#
#   Source/.env                              — docker compose (api + web)
#   Source/Backend/track-list-api/.env       — `dotnet run` / `dotnet test`
#                                              outside Docker
#   Source/Frontend/.env                     — Vite dev server + SvelteKit
#                                              SSR outside Docker
#   Source/seeder/.env                       — Python seeder (SEED_* vars)
#   Source/Tests/Performance/.env.perf       — k6 perf stack (overlay
#                                              compose with isolated DB/port)
#
# When rotating a key (e.g. JWT_PRIVATE_KEY, OMDB_API_KEY), update each
# file that references it. The .bin/Debug/.env and .bin/Release/.env
# copies under Backend/ are produced by `dotnet build` — do NOT edit
# those manually; rebuild after changing Backend/.env.
#
# Variable-name overlap across files:
#
#   Var                | Root | Backend | Frontend | Seeder | Perf |
#   -------------------|------|---------|----------|--------|------|
#   CONNECTION_STRING  |  ✓   |    ✓    |          |        |  ✓   |
#   JWT_PRIVATE_KEY    |  ✓   |    ✓    |          |        |  ✓   |
#   JWT_AUDIENCE       |  ✓   |    ✓    |          |        |  ✓   |
#   JWT_ISSUER         |  ✓   |    ✓    |          |        |  ✓   |
#   TMDBApiKey         |  ✓   |    ✓    |          |   ✓    |  ✓   |
#   OMDB_API_KEY       |  ✓   |    ✓    |          |        |  ✓   |
#   DEEPL_API_KEY      |  ✓   |    ✓    |          |        |  ✓   |
#   PUBLIC_API_URL     |  ✓   |    ✓    |    ✓     |        |  ✓   |
#   SEED_API_BASE      |      |         |          |   ✓    |      |
#   SEED_ADMIN_*       |      |         |          |   ✓    |      |
#
# All values use the SAME name in every file where they appear (after
# the seeder/TMDBApiKey fix). The seeder also accepts legacy
# TMDB_API_KEY for backward compatibility.
# ───────────────────────────────────────────────────────────────────

# ── Backend ────────────────────────────────────────────
# EF Core connection string. Default = SQLite at /app/data inside the container.
CONNECTION_STRING="Data Source=/app/data/tracklist.db;Cache=Shared;Mode=ReadWriteCreate;Foreign Keys=True"
FILE_STORAGE_PATH="/app/uploads"

# JWT — generate a fresh long random secret per environment.
# Linux/macOS: openssl rand -base64 64
# Windows PS:  [Convert]::ToBase64String((1..64 | % { [byte](Get-Random -Max 256) }))
JWT_PRIVATE_KEY="CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET"
JWT_AUDIENCE="track-list-web"
JWT_ISSUER="track-list-api"

# ── Self-host security defaults ───────────────────────
# Production-safe defaults: no default admin, no public signup, one user max.
# First admin is created once through /setup with TRACKLIST_SETUP_TOKEN.
TRACKLIST_SETUP_TOKEN="CHANGE_ME_GENERATE_A_LONG_RANDOM_SETUP_TOKEN"
TRACKLIST_PUBLIC_REGISTRATION=false
TRACKLIST_MAX_USERS=1
TRACKLIST_SEED_MODERATOR=false
TRACKLIST_ALLOWED_ORIGINS=
TRACKLIST_SHOW_PII=false

# ── External APIs ──────────────────────────────────────
# External HTTP integrations are opt-in. Enabling them leaks the searched
# media titles/external ids to that provider; DeepL also receives review text.
TRACKLIST_ENABLE_TMDB=false
TRACKLIST_ENABLE_OMDB=false
TRACKLIST_ENABLE_DEEPL=false
TRACKLIST_ENABLE_LETTERBOXD=false
TRACKLIST_ENABLE_WIKIPEDIA=false

# TMDB — media import + search. Free key at
# https://www.themoviedb.org/settings/api
TMDBApiKey=

# OMDb — IMDb / Rotten Tomatoes / Metacritic ratings. Free 1000/day at
# http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# DeepL — translation of external reviews/wiki. Free 500k chars/month at
# https://www.deepl.com/en/your-account/keys (suffix :fx denotes Free tier)
DEEPL_API_KEY=

# ── Frontend ───────────────────────────────────────────
# Optional override. If omitted, the frontend uses same-origin /api.
PUBLIC_API_URL=http://localhost/api
